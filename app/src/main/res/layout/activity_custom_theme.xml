<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_beige">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_beige"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/background_beige"
            app:titleTextColor="@color/text_dark" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Customize Theme Colors"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap on any color to change it. Enter hex color codes (#RRGGBB)."
                android:textSize="14sp"
                android:textColor="@color/text_gray"
                android:layout_marginBottom="24dp" />

            <!-- Background Color -->
            <LinearLayout
                android:id="@+id/bgColorRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/bgColorPreview"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@android:color/white" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Background Color"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/bgColorValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#FFFFFF"
                        android:textColor="@color/text_gray"
                        android:textSize="14sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- Text Color -->
            <LinearLayout
                android:id="@+id/textColorRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/textColorPreview"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@color/text_dark" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Text Color"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/textColorValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#1A1A1A"
                        android:textColor="@color/text_gray"
                        android:textSize="14sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- Secondary Text Color -->
            <LinearLayout
                android:id="@+id/secondaryTextColorRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/secondaryTextColorPreview"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@color/text_gray" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Secondary Text Color"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/secondaryTextColorValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#757575"
                        android:textColor="@color/text_gray"
                        android:textSize="14sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- Link Color -->
            <LinearLayout
                android:id="@+id/linkColorRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/linkColorPreview"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="#2196F3" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Link Color"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/linkColorValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#2196F3"
                        android:textColor="@color/text_gray"
                        android:textSize="14sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- Accent Color -->
            <LinearLayout
                android:id="@+id/accentColorRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/accentColorPreview"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@color/accent_red" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Accent Color"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/accentColorValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#FF6B6B"
                        android:textColor="@color/text_gray"
                        android:textSize="14sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- Code Background Color -->
            <LinearLayout
                android:id="@+id/codeBackgroundColorRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/codeBackgroundColorPreview"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="#F5F5F5" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Code Background Color"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/codeBackgroundColorValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#F5F5F5"
                        android:textColor="@color/text_gray"
                        android:textSize="14sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- Border Color -->
            <LinearLayout
                android:id="@+id/borderColorRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/borderColorPreview"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="#E0E0E0" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Border Color"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/borderColorValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#E0E0E0"
                        android:textColor="@color/text_gray"
                        android:textSize="14sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- Button Color -->
            <LinearLayout
                android:id="@+id/buttonColorRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/buttonColorPreview"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@color/accent_red" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Button Color"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/buttonColorValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#FF6B6B"
                        android:textColor="@color/text_gray"
                        android:textSize="14sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- Dot Color -->
            <LinearLayout
                android:id="@+id/dotColorRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/dotColorPreview"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="#BDBDBD" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dot Color"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/dotColorValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#BDBDBD"
                        android:textColor="@color/text_gray"
                        android:textSize="14sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- Today Dot Color -->
            <LinearLayout
                android:id="@+id/todayDotColorRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/todayDotColorPreview"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@color/accent_red" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today Dot Color"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/todayDotColorValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#FF6B6B"
                        android:textColor="@color/text_gray"
                        android:textSize="14sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- Date Background Color -->
            <LinearLayout
                android:id="@+id/dateBackgroundColorRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/dateBackgroundColorPreview"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="#F0F0F0" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date Background Color"
                        android:textColor="@color/text_dark"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/dateBackgroundColorValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#F0F0F0"
                        android:textColor="@color/text_gray"
                        android:textSize="14sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/saveButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Save Custom Theme"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/accent_red" />

</LinearLayout>
