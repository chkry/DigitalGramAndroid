<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp">

    <!-- Timeline Column - centered dot only -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <!-- Top line (hidden) -->
        <View
            android:id="@+id/lineTop"
            android:layout_width="2dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- Dot -->
        <View
            android:id="@+id/timelineDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/timeline_dot" />

        <!-- Bottom line (hidden) -->
        <View
            android:id="@+id/lineBottom"
            android:layout_width="2dp"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Entry Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/entryCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginVertical="4dp"
        android:alpha="0.7"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/border_black"
        app:strokeWidth="2dp"
        app:cardBackgroundColor="@color/background_beige">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:minHeight="72dp">

            <!-- Date Box -->
            <LinearLayout
                android:id="@+id/dateBox"
                android:layout_width="72dp"
                android:layout_height="match_parent"
                android:background="@drawable/date_box_border"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/dayName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-condensed"
                    android:text="MON"
                    android:textColor="@color/text_gray"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/dayNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-condensed"
                    android:text="15"
                    android:textColor="@color/accent_red"
                    android:textSize="28sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Content -->
            <TextView
                android:id="@+id/entryContent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:ellipsize="end"
                android:maxLines="3"
                android:padding="12dp"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
